PORT=5050
NODE_ENV=development

# OpenAI - Whisper ASR
OPENAI_API_KEY=

# Anthropic - Claude LLM
ANTHROPIC_API_KEY=

# ElevenLabs - TTS
ELEVEN_API_KEY=
ELEVEN_VOICE_ID=
ELEVEN_MODEL_ID=eleven_multilingual_v2

# Shopmata API
SHOPMATA_API_URL=https://shopmata.com
SHOPMATA_INTERNAL_KEY=

# CORS
ALLOWED_ORIGINS=https://shopmata.com

# FFmpeg binary path
FFMPEG_BIN=/usr/bin/ffmpeg

# Self-hosted Whisper (optional, for GPU deployments)
# Set ASR_PROVIDER=local and WHISPER_URL to use self-hosted faster-whisper
# instead of OpenAI API. See whisper/ directory for the ASR service.
# ASR_PROVIDER=local
# WHISPER_URL=ws://localhost:8000/v1/asr/stream
